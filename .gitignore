#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Firebase Cloud Functions
functions/node_modules/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Secrets & local config (never commit keys/passwords here)
.env
.env.*
*.pem
*.p12
**/firebase-adminsdk*.json
**/*serviceAccount*.json
lib/bible/api_bible_local_key.dart
lib/firebase_options.dart
android/app/google-services.json

# Bundled Bible JSON under assets/bible/ is required in git for offline reading
# and CI APK builds — do NOT add assets/bible/ here.

# Docs / notes (optional local only)
*.md
!ios/cloud-build/
