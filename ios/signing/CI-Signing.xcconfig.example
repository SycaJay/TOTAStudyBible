// Copy to ios/Flutter/CI-Signing.xcconfig for local signed IPA builds (do not commit real values).
// GitHub Actions writes CI-Signing.xcconfig automatically during cloud builds.

DEVELOPMENT_TEAM=YOUR_APPLE_TEAM_ID
CODE_SIGN_STYLE=Manual
CODE_SIGN_IDENTITY=Apple Distribution
PROVISIONING_PROFILE_SPECIFIER=YOUR_PROVISIONING_PROFILE_NAME
